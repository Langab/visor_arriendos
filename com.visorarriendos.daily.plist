<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.visorarriendos.daily</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/langa/Desktop/visor_arriendos/run_daily.sh</string>
    </array>

    <!-- Todos los días a las 10:00 -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>10</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/langa/Desktop/visor_arriendos/data/cron.out</string>
    <key>StandardErrorPath</key>
    <string>/Users/langa/Desktop/visor_arriendos/data/cron.err</string>

    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
